{
  "name": "@openfoodfacts/react-native",
  "version": "2.0.0-alpha.1",
  "description": "React Native SDK for Open Food Facts – wraps @openfoodfacts/openfoodfacts-nodejs with React Native helpers, hooks, and image-upload utilities",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:esm": "tsc --project tsconfig.build.json --module es2020 --outDir dist/esm",
    "build:cjs": "tsc --project tsconfig.build.json --module commonjs --outDir dist/cjs",
    "build:types": "tsc --project tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist/types",
    "build": "npm run clean && npm run build:esm && npm run build:cjs && npm run build:types",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openfoodfacts",
    "react-native",
    "food",
    "barcode",
    "nutrition",
    "open-data",
    "sdk"
  ],
  "author": "Open Food Facts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/openfoodfacts/openfoodfacts-react-native.git"
  },
  "bugs": {
    "url": "https://github.com/openfoodfacts/openfoodfacts-react-native/issues"
  },
  "homepage": "https://github.com/openfoodfacts/openfoodfacts-react-native#readme",
  "dependencies": {
    "@openfoodfacts/openfoodfacts-nodejs": "^2.0.0-alpha.30"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "react": "^18.3.1",
    "react-native": "^0.76.0",
    "ts-jest": "^29.2.4",
    "typescript": "^5.5.4"
  }
}
